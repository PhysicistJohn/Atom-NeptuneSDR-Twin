+#define P210_CPU1_RST      BIT(1)
+#define P210_CPU1_CLKSTOP  BIT(5)
+
+static void p210_start_secondary_async(CPUState *cs, run_on_cpu_data data)
+{
+    ARMCPU *cpu = ARM_CPU(cs);
+
+    cpu_reset(cs);
+    arm_emulate_firmware_reset(cs,
+                               arm_feature(&cpu->env, ARM_FEATURE_EL2) ? 2 : 1);
+    /* Linux installs the real Zynq two-instruction trampoline at 0x0. */
+    cpu_set_pc(cs, 0x00000000);
+    cs->halted = 0;
+    if (tcg_enabled()) {
+        arm_rebuild_hflags(&cpu->env);
+    }
+}
+
+static uint64_t p210_cpu_rst_read(void *opaque, hwaddr offset, unsigned size)
+{
+    return ZYNQ_MACHINE(opaque)->p210_cpu_rst_ctrl;
+}
+
+static void p210_cpu_rst_write(void *opaque, hwaddr offset, uint64_t value,
+                               unsigned size)
+{
+    ZynqMachineState *s = ZYNQ_MACHINE(opaque);
+    uint32_t old = s->p210_cpu_rst_ctrl;
+    uint32_t val = value;
+    uint32_t cpu1_stop = P210_CPU1_RST | P210_CPU1_CLKSTOP;
+
+    s->p210_cpu_rst_ctrl = val;
+    if ((old & cpu1_stop) && !(val & cpu1_stop) && s->cpu[1]) {
+        async_run_on_cpu(CPU(s->cpu[1]), p210_start_secondary_async,
+                         RUN_ON_CPU_NULL);
+    }
+}
+
+static const MemoryRegionOps p210_cpu_rst_ops = {
+    .read = p210_cpu_rst_read,
+    .write = p210_cpu_rst_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid.min_access_size = 4,
+    .valid.max_access_size = 4,
+    .impl.min_access_size = 4,
+    .impl.max_access_size = 4,
+};
